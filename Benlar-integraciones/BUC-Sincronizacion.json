  "item": [
    {
      "name": "BUC - Sincronización",
      "item": [
        {
          "name": "REQ FUN 01 - Obtener usuarios creados y/o modificados",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "//definicion del contrato json\r",
                  "const schema = {\r",
                  "  \"type\": \"object\",\r",
                  "  \"required\": [\r",
                  "    \"statusCode\", \r",
                  "    \"statusTitle\", \r",
                  "    \"path\", \r",
                  "    \"method\", \r",
                  "    \"message\", \r",
                  "    \"data\", \r",
                  "    \"timestamp\", \r",
                  "    \"requestId\"\r",
                  "    ],\r",
                  "  \"properties\": {\r",
                  "    \"statusCode\": { \"type\": \"integer\" },\r",
                  "    \"statusTitle\": { \"type\": \"string\" },\r",
                  "    \"path\": { \"type\": \"string\" },\r",
                  "    \"method\": { \"type\": \"string\" },\r",
                  "    \"message\": {\r",
                  "      \"type\": \"array\",\r",
                  "      \"items\": { \"type\": \"string\" }\r",
                  "    },\r",
                  "    \"data\": {\r",
                  "      \"type\": \"array\",\r",
                  "      \"items\": {\r",
                  "        \"type\": \"object\",\r",
                  "        \"required\": [\"taxId\", \"policyNumber\"],\r",
                  "        \"properties\": {\r",
                  "          \"taxId\": { \"type\": \"string\" },\r",
                  "          \"policyNumber\": { \"type\": \"string\" },\r",
                  "        }\r",
                  "      }\r",
                  "    },\r",
                  "    \"timestamp\": { \"type\": \"string\" },\r",
                  "    \"requestId\": { \"type\": \"string\" }\r",
                  "  }\r",
                  "};\r",
                  "\r",
                  "//obtencion de la respuesta en formato json.\r",
                  "const response = pm.response.json();\r",
                  "\r",
                  "//Pruebas de validación del contrato json.\r",
                  "pm.test(\"Formato de response corresponde al esperado\",()=>{\r",
                  "    const Ajv = require('ajv');\r",
                  "    const ajv = new Ajv({ allErrors: true});\r",
                  "    const validar = ajv.compile(schema);\r",
                  "    const esValido = validar(response)\r",
                  "\r",
                  "    if (!esValido) {\r",
                  "        //se muestran los errores de validación por consola\r",
                  "        console.log(\"Errores de validación:\", validar.errors);\r",
                  "\r",
                  "        //se formatean los errores para mostrarlos en el reporte de Postman\r",
                  "        const detalleError = validar.errors.map(err => {\r",
                  "            const path = err.dataPath || \"root\";\r",
                  "            return `${path}: ${err.message}`});\r",
                  "        pm.expect.fail(\"Fallo en el esquema: \" + detalleError);\r",
                  "    }\r",
                  "\r",
                  "    pm.expect(esValido).to.be.true;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Formato de TaxId 12345678-9 corresponde al esperado\", () => {\r",
                  "    for (let i = 0; i < response.data.length; i++) {\r",
                  "        pm.expect(response.data[i].taxId).to.match(/^\\d{7,8}-[\\dkK]$/);\r",
                  "    }\r",
                  "})\r",
                  "\r",
                  "pm.test(\"Tiempo de respuesta menor o igual a 500ms\", ()=> {\r",
                  "    pm.expect(pm.response.responseTime).to.be.below(500);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Mensaje contiene texto esperado\", ()=>{\r",
                  "    regex404 = /No se encontraron registros con los criterios/i\r",
                  "    regex200 = /Solicitud completada con éxito/i\r",
                  "    switch (response.statusCode) {\r",
                  "        case 200:\r",
                  "        pm.expect(response.message).to.match(regex200);\r",
                  "        break;\r",
                  "        case 404:\r",
                  "        pm.expect(response.message).to.match(regex404)\r",
                  "        break;\r",
                  "        default: pm.expect.fail('Error 500 o date vacío o inválido')\r",
                  "    }\r",
                  "})\r",
                  "\r",
                  "\r",
                  ""
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json",
                "type": "text"
              }
            ],
            "url": {
              "raw": "http://benlar-products.qa.seguros.local/v1/persons/history/action?dateFrom=2025-05-20&dateTo=2025-05-20",
              "host": [
                "http://benlar-products.qa.seguros.local"
              ],
              "path": [
                "v1",
                "persons",
                "history",
                "action"
              ],
              "query": [
                {
                  "key": "dateFrom",
                  "value": "2025-05-20",
                  "description": "Formato: yyyy-MM-dd (requerido)"
                },
                {
                  "key": "dateTo",
                  "value": "2025-05-20",
                  "description": "Formato: yyyy-MM-dd"
                }
              ]
            },
            "description": "Obtiene los datos de usuarios creados y/o modificados en el rango de fechas indicado.\nREQ FUN 01 - BUC_POLIZAS_LISTADO"
          },
          "response": []
        },
        {
