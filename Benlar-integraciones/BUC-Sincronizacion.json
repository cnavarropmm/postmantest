            "description": "Generated from cURL: curl -X 'GET' \\\r\n  'http://benlar-products.qa.seguros.local/v1/clients/policies/uncollected' \\\r\n  -H 'accept: text/plain'"
          },
          "response": []
        }
      ]
    }
  ]
